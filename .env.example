# LLM local — NLP + orchestration (Ollama, CPU)
# Modèle recommandé : qwen2.5:7b ou qwen2.5:3b si latence trop élevée
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_BASE_URL=http://localhost:11434

# LLM chatbot (optionnel — désactiver en laissant vide)
# Si renseigné, activé pour la formulation conversationnelle uniquement
CHATGPT_API_KEY=
CHATGPT_MODEL=gpt-4o-mini

# Serveur
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Nominatim
NOMINATIM_USER_AGENT=findme-app-v3
NOMINATIM_TIMEOUT=10

# OSRM
OSRM_BASE_URL=http://router.project-osrm.org

# SNCF Navitia API — https://navitia.io/inscription/
# Laisser vide pour désactiver les modes ferroviaires (train, ter, tgv, bus)
SNCF_NAVITIA_KEY=
